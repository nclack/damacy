{
  "name": "smoke",
  "dataset": {
    "store_root": "bench/data/bench.zarr",
    "n_zarrs": 1,
    "uri_fmt": "scale0/image",
    "array_path": "scale0/image",
    "zarr_shape": [64, 1024, 1024],
    "chunk_shape": [32, 128, 128],
    "shard_shape": [64, 512, 512],
    "dtypes": ["u16"],
    "codecs": ["zstd"],
    "clevel": 3,
    "entropy": 0.5,
    "seed": 42
  },
  "sampling": {
    "sample_shape": [32, 128, 128],
    "n_batches": 8,
    "n_warmup_batches": 2,
    "samples_per_batch": 4,
    "seed": 1234
  },
  "pipeline": {
    "dtype": "f32",
    "lookahead_samples": 16,
    "n_io_threads": 4,
    "metadata_io_concurrency": 32,
    "max_gpu_memory_mb": 512,
    "max_chunk_uncompressed_mb": 1,
    "n_array_meta_cache": 16,
    "n_shard_index_cache": 128,
    "n_chunk_layout_cache": 16,
    "max_shards_per_sample": 8
  }
}
